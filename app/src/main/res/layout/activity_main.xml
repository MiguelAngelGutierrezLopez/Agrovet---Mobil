<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/blanco_hueso"
    tools:context=".MainActivity">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@color/teal"
                android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
                app:titleTextColor="@color/white"
                android:paddingHorizontal="20dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/agro_caps"
                            android:textColor="@color/teal"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/vet_caps"
                            android:textColor="@color/mostaza"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/app_mobil"
                            android:textColor="@color/gris_oscuro"
                            android:textSize="14sp"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/resumen_general"
                        style="@style/TextAppearance.Agrovet.Label"
                        android:layout_marginBottom="12dp" />

                    <!-- Fila 1: PRODUCTOS Y VENTAS HOY -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/card_productos"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="5dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp"
                            android:backgroundTint="@color/white">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp"
                                android:background="@drawable/bg_stat_ingresos">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/total_productos"
                                    style="@style/TextAppearance.Agrovet.Label"
                                    android:textColor="@color/teal" />

                                <TextView
                                    android:id="@+id/txt_total_productos"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/gris_oscuro"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:id="@+id/card_ventas_hoy"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="5dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp"
                            android:backgroundTint="@color/white">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp"
                                android:background="@drawable/bg_stat_ventas">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/ventas_hoy"
                                    style="@style/TextAppearance.Agrovet.Label"
                                    android:textColor="@color/mostaza" />

                                <TextView
                                    android:id="@+id/txt_ventas_hoy"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/gris_oscuro"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <!-- Fila 2: CLIENTES Y CAJA -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="24dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/card_clientes"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="5dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp"
                            android:backgroundTint="@color/white">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp"
                                android:background="@drawable/bg_stat_pendiente">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/total_clientes"
                                    style="@style/TextAppearance.Agrovet.Label"
                                    android:textColor="@color/terracota" />

                                <TextView
                                    android:id="@+id/txt_total_clientes"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/gris_oscuro"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:id="@+id/card_reporte_caja"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="5dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp"
                            android:backgroundTint="@color/white">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp"
                                android:background="@drawable/bg_stat_ingresos">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/saldo_caja"
                                    style="@style/TextAppearance.Agrovet.Label"
                                    android:textColor="@color/teal" />

                                <TextView
                                    android:id="@+id/txt_caja_saldo"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="$ 0"
                                    android:textColor="@color/gris_oscuro"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tendencia de Ventas"
                        style="@style/TextAppearance.Agrovet.Label"
                        android:layout_marginBottom="12dp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:layout_marginBottom="24dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        android:backgroundTint="@color/white">

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chart_ventas"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="8dp" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/txt_db_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/sesion_admin"
                        android:textColor="@color/gris_medio"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_marginTop="24dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">

                        <Button
                            android:id="@+id/btn_sync_to_web"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_sync_web"
                            android:backgroundTint="@color/turquesa"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:padding="12dp"
                            app:cornerRadius="8dp" />

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="8dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_manual_reboot"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/btn_recibir_datos"
                                android:textColor="@color/teal"
                                android:textSize="12sp"
                                app:icon="@android:drawable/stat_notify_sync"
                                app:iconTint="@color/teal"
                                android:background="@android:color/transparent"
                                android:contentDescription="@string/btn_recibir_datos" />

                            <View
                                android:id="@+id/indicator_sync_needed"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_gravity="top|end"
                                android:layout_marginTop="6dp"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/bg_circle_terracota"
                                android:visibility="gone" />
                        </FrameLayout>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progress_main_sync"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        android:indeterminate="true" />


                </LinearLayout>
            </ScrollView>
        </LinearLayout>

        <!-- Botón para ver Logs (Logger) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_view_logs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:src="@android:drawable/ic_menu_info_details"
            app:backgroundTint="@color/gris_oscuro"
            app:tint="@color/white"
            app:fabSize="mini"
            android:contentDescription="Ver Logs" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header_main"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
