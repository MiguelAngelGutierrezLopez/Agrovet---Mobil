<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_dialog_corporate">

        <TextView
            android:id="@+id/titulo_dialog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_producto"
            style="@style/TextAppearance.Agrovet.Headline.Dialog"
            android:layout_marginBottom="24dp" />

        <!-- Campo: Código -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_codigo"
            style="@style/TextAppearance.Agrovet.Label.Field" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.Agrovet.TextInputLayout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_codigo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ej. 001"
                android:inputType="number"
                android:textColor="@android:color/black"
                android:textColorHint="@color/gris_medio"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo: Nombre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_nombre_producto"
            style="@style/TextAppearance.Agrovet.Label.Field" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.Agrovet.TextInputLayout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_nombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ej. Arroz, Aceite, Harina"
                android:textColor="@android:color/black"
                android:textColorHint="@color/gris_medio"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo: Categoría -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_categoria"
            style="@style/TextAppearance.Agrovet.Label.Field" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cg_categorias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:singleSelection="true"
            app:selectionRequired="true">
            <!-- Chips se añadirán dinámicamente o estáticamente -->
        </com.google.android.material.chip.ChipGroup>

        <!-- Precio y Unidades en la misma fila -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- Campo: Precio -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_precio"
                    style="@style/TextAppearance.Agrovet.Label.Field" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Agrovet.TextInputLayout">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_precio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="0.00"
                        android:inputType="numberDecimal"
                        android:textColor="@android:color/black"
                        android:textColorHint="@color/gris_medio"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Campo: Unidades -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_stock"
                    style="@style/TextAppearance.Agrovet.Label.Field" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Agrovet.TextInputLayout">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_stock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="0"
                        android:inputType="number"
                        android:textColor="@android:color/black"
                        android:textColorHint="@color/gris_medio"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Campo: Presentación -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/et_presentacion"
            style="@style/TextAppearance.Agrovet.Label.Field" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.Agrovet.TextInputLayout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_presentacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ej. 1kg, 500ml, Caja x12"
                android:textColor="@android:color/black"
                android:textColorHint="@color/gris_medio"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Campo: Proveedor -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_proveedores"
            style="@style/TextAppearance.Agrovet.Label.Field" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.Agrovet.TextInputLayout.ExposedDropdownMenu"
            android:layout_marginBottom="24dp">

            <AutoCompleteTextView
                android:id="@+id/et_producto_proveedor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Seleccione un proveedor"
                android:inputType="none"
                android:textColor="@android:color/black" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/btn_cancelar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_cancelar"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@color/gris_medio" />

            <Button
                android:id="@+id/btn_guardar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_guardar"
                style="@style/Widget.Agrovet.Button.Primary"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
