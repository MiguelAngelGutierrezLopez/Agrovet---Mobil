<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    android:backgroundTint="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:background="@drawable/bg_card_border"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_movimiento_razon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_razon_movimiento"
                android:textColor="@color/gris_oscuro"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txt_movimiento_fecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_fecha"
                android:textColor="@color/gris_medio"
                android:textSize="11sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txt_movimiento_monto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$ 0.00"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/verde_exito" />

        <LinearLayout
            android:id="@+id/layout_acciones_movimiento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="12dp">

            <Button
                android:id="@+id/btn_editar"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/btn_editar_caps"
                android:textSize="10sp"
                android:textColor="@color/teal"
                android:background="@android:color/transparent"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btn_eliminar"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/btn_eliminar_caps"
                android:textSize="10sp"
                android:textColor="@color/rojo_error"
                android:background="@android:color/transparent"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>