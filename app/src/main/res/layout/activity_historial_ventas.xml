<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/blanco_hueso">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@color/teal"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:titleTextColor="@color/white"
            app:title="Historial de Ventas" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ingresos por Categoría de Pago"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/gris_oscuro"
                    android:layout_marginBottom="6dp" />

                <!-- BANCO -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    app:cardCornerRadius="6dp"
                    app:cardElevation="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp"
                        android:background="@drawable/bg_stat_ingresos">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BANCO"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="@color/teal"
                            android:layout_marginBottom="2dp"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="1dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Ingresos:"
                                android:textSize="10sp"
                                android:textColor="@color/gris_oscuro"/>
                            <TextView
                                android:id="@+id/txt_banco_ingresos"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/teal"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="1dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Ventas:"
                                android:textSize="10sp"
                                android:textColor="@color/gris_oscuro"/>
                            <TextView
                                android:id="@+id/txt_banco_cantidad"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="11sp"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/txt_banco_subtipos"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Métodos: -"
                            android:textSize="9sp"
                            android:textColor="@color/gris_medio"
                            android:layout_marginTop="2dp"
                            android:maxLines="1"
                            android:ellipsize="end"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- CONTADO -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    app:cardCornerRadius="6dp"
                    app:cardElevation="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp"
                        android:background="@drawable/bg_stat_ingresos">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/contado"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="@color/teal"
                            android:layout_marginBottom="2dp"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="1dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/ingresos"
                                android:textSize="10sp"
                                android:textColor="@color/gris_oscuro"/>
                            <TextView
                                android:id="@+id/txt_contado_ingresos"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/_0"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/teal"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/ventas"
                                android:textSize="10sp"
                                android:textColor="@color/gris_oscuro"
                                tools:ignore="SmallSp" />
                            <TextView
                                android:id="@+id/txt_contado_cantidad"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/_0_"
                                android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- CRÉDITO -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="6dp"
                    app:cardElevation="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp"
                        android:background="@drawable/bg_stat_pendiente">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cr_dito"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="@color/terracota"
                            android:layout_marginBottom="2dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="1dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/anticipos"
                                android:textSize="10sp"
                                android:textColor="@color/gris_oscuro"
                                tools:ignore="SmallSp" />
                            <TextView
                                android:id="@+id/txt_credito_ingresos"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/_0_0"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/terracota"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="1dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/ventas_"
                                android:textSize="10sp"
                                android:textColor="@color/gris_oscuro"
                                tools:ignore="SmallSp" />
                            <TextView
                                android:id="@+id/txt_credito_cantidad"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="11sp"
                                android:textColor="@color/gris_oscuro"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="1dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Total venta:"
                                android:textSize="10sp"
                                android:textColor="@color/gris_oscuro"/>
                            <TextView
                                android:id="@+id/txt_credito_total"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0"
                                android:textSize="11sp"
                                android:textColor="@color/gris_oscuro"/>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/gris_medio"
                            android:layout_marginVertical="3dp"
                            android:alpha="0.3" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Saldo pendiente:"
                                android:textStyle="bold"
                                android:textSize="10sp"
                                android:textColor="@color/terracota" />
                            <TextView
                                android:id="@+id/txt_credito_pendiente"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$0"
                                android:textStyle="bold"
                                android:textSize="11sp"
                                android:textColor="@color/terracota" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>

        <!-- Period Buttons -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button android:id="@+id/btn_periodo_hoy"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Hoy"
                    android:textSize="10sp"
                    android:paddingHorizontal="12dp"
                    style="@style/Widget.Agrovet.Button.Period" />
                <View android:layout_width="6dp" android:layout_height="0dp" />
                <Button android:id="@+id/btn_periodo_semana"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Semana"
                    android:textSize="10sp"
                    android:paddingHorizontal="12dp"
                    style="@style/Widget.Agrovet.Button.Period" />
                <View android:layout_width="6dp" android:layout_height="0dp" />
                <Button android:id="@+id/btn_periodo_mes"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Mes"
                    android:textSize="10sp"
                    android:paddingHorizontal="12dp"
                    style="@style/Widget.Agrovet.Button.Period" />
                <View android:layout_width="6dp" android:layout_height="0dp" />
                <Button android:id="@+id/btn_periodo_anio"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Año"
                    android:textSize="10sp"
                    android:paddingHorizontal="12dp"
                    style="@style/Widget.Agrovet.Button.Period" />
            </LinearLayout>
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_historial_ventas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="12dp"
            android:clipToPadding="false" />

    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header_main"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
