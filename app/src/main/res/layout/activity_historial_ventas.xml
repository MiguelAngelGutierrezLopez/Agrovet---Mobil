<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/blanco_hueso">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/teal"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:title="@string/titulo_historial"
        app:titleTextColor="@color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/white"
        android:elevation="2dp"
        android:layout_margin="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/txt_stats_ventas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/teal"
                android:textStyle="bold"
                android:textSize="18sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_ventas"
                android:textSize="10sp"
                android:textColor="@color/gris_medio" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/txt_stats_ingresos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$ 0"
                android:textColor="@color/verde_exito"
                android:textStyle="bold"
                android:textSize="18sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_ingresos"
                android:textSize="10sp"
                android:textColor="@color/gris_medio" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/txt_stats_utilidad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$ 0"
                android:textColor="@color/turquesa"
                android:textStyle="bold"
                android:textSize="18sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_utilidad"
                android:textSize="10sp"
                android:textColor="@color/gris_medio" />
        </LinearLayout>

    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="12dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btn_periodo_hoy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/periodo_hoy"
                android:minHeight="0dp"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:backgroundTint="@color/teal"
                android:textColor="@color/white" />
            <Button
                android:id="@+id/btn_periodo_semana"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/periodo_semana"
                android:minHeight="0dp"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@color/gris_oscuro" />
            <Button
                android:id="@+id/btn_periodo_mes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/periodo_mes"
                android:minHeight="0dp"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@color/gris_oscuro" />
            <Button
                android:id="@+id/btn_periodo_anio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/periodo_anio"
                android:minHeight="0dp"
                android:paddingHorizontal="16dp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@color/gris_oscuro" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_historial_ventas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:clipToPadding="false" />

</LinearLayout>
