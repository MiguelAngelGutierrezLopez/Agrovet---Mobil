<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_corporate">

    <TextView
        android:id="@+id/txt_detalle_titulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_resumen_venta"
        style="@style/TextAppearance.Agrovet.Headline.Dialog"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_border"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/txt_detalle_ticket"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ticket_placeholder"
            android:textColor="@color/gris_oscuro"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txt_detalle_fecha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/fecha_placeholder"
            android:textColor="@color/gris_medio"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/txt_detalle_cliente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cliente_placeholder"
            android:textColor="@color/gris_oscuro"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/txt_detalle_pago"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pago_placeholder"
            android:textColor="@color/teal"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tab_productos"
        style="@style/TextAppearance.Agrovet.Label"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_detalle_productos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="200dp"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gris_claro"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/label_total"
            android:textColor="@color/gris_oscuro"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txt_detalle_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/monto_placeholder"
            android:textColor="@color/teal"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_detalle_cerrar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_cerrar_caps"
        style="@style/Widget.Agrovet.Button.Primary"
        android:layout_marginTop="24dp" />

</LinearLayout>
