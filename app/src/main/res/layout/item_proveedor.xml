<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    style="@style/Widget.Agrovet.Card.ListItem">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:background="@drawable/bg_card_border">

        <TextView
            android:id="@+id/txt_empresa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_nombre_empresa"
            android:textColor="@color/gris_oscuro"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txt_nombre_proveedor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_nombre_contacto"
            android:textColor="@color/teal"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/txt_telefono"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/tel_prefix"
                android:textColor="@color/gris_medio"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/txt_estado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_activo"
                android:textColor="@color/verde_exito"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/txt_productos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/productos_prefix"
            android:textColor="@color/gris_medio"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            android:maxLines="2"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:paddingTop="10dp"
            android:background="@drawable/bg_top_divider">

            <Button
                android:id="@+id/btn_editar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_editar_caps"
                style="@style/Widget.Agrovet.Button.Action.Edit" />

            <View android:layout_width="10dp" android:layout_height="0dp" />

            <Button
                android:id="@+id/btn_eliminar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_eliminar_caps"
                style="@style/Widget.Agrovet.Button.Action.Delete" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
