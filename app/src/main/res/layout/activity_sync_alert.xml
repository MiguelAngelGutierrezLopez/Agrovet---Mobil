<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#80000000">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@android:drawable/ic_popup_sync"
                app:tint="@color/teal"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/txt_alert_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hemos detectado que hubo un cambio en el servidor. ¿Quiere reiniciar la aplicación ahora para actualizar los datos?"
                android:textSize="16sp"
                android:textColor="@color/gris_oscuro"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btn_sync_now"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="REINICIAR Y ACTUALIZAR"
                android:backgroundTint="@color/turquesa"
                android:textColor="@color/white"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_sync_later"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DESPUÉS / MANUALMENTE"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="@color/gris_medio" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
