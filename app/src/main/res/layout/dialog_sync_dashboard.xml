<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_corporate">

    <TextView
        android:id="@+id/txt_sync_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sincronización de Datos"
        style="@style/TextAppearance.Agrovet.Headline.Dialog"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/txt_sync_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cargando resumen..."
        android:textSize="14sp"
        android:textColor="@color/gris_oscuro"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/txt_sync_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="@color/terracota"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/progress_sync"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btn_corregir_formatos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Corregir formatos"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@color/gris_medio" />

        <Button
            android:id="@+id/btn_enviar_datos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enviar datos"
            style="@style/Widget.Agrovet.Button.Primary"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
