<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/blanco_hueso">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/teal"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:titleTextColor="@color/white"
        app:title="Registro de Venta"
        android:paddingStart="20dp"
        android:paddingEnd="20dp" />

    <!-- Indicador de Pasos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:padding="16dp"
        android:elevation="0dp">

        <TextView
            android:id="@+id/step1_indicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1. PRODUCTOS"
            android:textColor="@color/teal"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/step2_indicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2. PAGO"
            android:textColor="@color/gris_medio"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.05" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- PASO 1: Selección de Productos -->
        <LinearLayout
            android:id="@+id/layout_step1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/et_buscar_producto"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Buscar producto..."
                    android:padding="12dp"
                    android:background="@drawable/bg_edittext_corporate"
                    android:textColor="@color/gris_oscuro"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_venta_especifica"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VENTA ESPECÍFICA"
                    android:textSize="10sp"
                    android:layout_marginStart="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/teal"
                    android:textColor="@color/teal" />
            </LinearLayout>

            <!-- Selector de Cliente (Visible si es Venta Específica) -->
            <AutoCompleteTextView
                android:id="@+id/et_buscar_cliente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre del cliente..."
                android:padding="12dp"
                android:background="@drawable/bg_edittext_corporate"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                android:textSize="13sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_productos_disponibles"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                android:layout_marginTop="12dp"
                app:cardElevation="0dp"
                android:backgroundTint="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:background="@drawable/bg_card_border">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ITEMS EN CARRITO"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/gris_medio" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_carrito"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="4dp" />

                    <Button
                        android:id="@+id/btn_next_step"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="CONTINUAR AL PAGO"
                        android:backgroundTint="@color/teal"
                        android:textColor="@color/white"
                        android:layout_marginTop="8dp"
                        app:cornerRadius="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- PASO 2: Resumen y Pago -->
        <ScrollView
            android:id="@+id/layout_step2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RESUMEN DE VENTA"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/teal"
                    android:layout_marginBottom="24dp"
                    android:letterSpacing="0.05" />

                <!-- Descuento -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Descuento ($)" android:textColor="@color/gris_medio" />
                    <EditText
                        android:id="@+id/et_descuento"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:text="0"
                        android:gravity="end"
                        android:background="@drawable/bg_edittext_corporate"
                        android:padding="8dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Subtotal" android:textColor="@color/gris_medio" />
                    <TextView android:id="@+id/txt_resumen_subtotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$ 0.00" android:textColor="@color/gris_oscuro" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="TOTAL A PAGAR" android:textSize="16sp" android:textStyle="bold" android:textColor="@color/gris_oscuro" />
                    <TextView android:id="@+id/txt_total_venta" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$ 0.00" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/gris_oscuro" />
                </LinearLayout>

                <!-- Monto Recibido y Vuelto -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Monto Recibido" android:textColor="@color/gris_oscuro" />
                    <EditText
                        android:id="@+id/et_monto_recibido"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:hint="0.00"
                        android:gravity="end"
                        android:background="@drawable/bg_edittext_corporate"
                        android:padding="10dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="32dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="CAMBIO / VUELTO" android:textStyle="bold" android:textColor="@color/verde_exito" />
                    <TextView android:id="@+id/txt_vuelto" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="$ 0.00" android:textStyle="bold" android:textColor="@color/verde_exito" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MÉTODO DE PAGO"
                    android:textColor="@color/gris_medio"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <RadioGroup
                    android:id="@+id/rg_metodo_pago"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="24dp">
                    <RadioButton android:id="@+id/rb_contado" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="EFECTIVO / CONTADO" android:textSize="12sp" android:textColor="@color/gris_oscuro" android:checked="true" />
                    <RadioButton android:id="@+id/rb_credito" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="CRÉDITO" android:textSize="12sp" android:textColor="@color/gris_oscuro" />
                    <RadioButton android:id="@+id/rb_banco" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="BANCO / TRANSFERENCIA" android:textSize="12sp" android:textColor="@color/gris_oscuro" />
                </RadioGroup>

                <!-- Anticipo (Solo para Crédito) -->
                <LinearLayout
                    android:id="@+id/layout_anticipo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="32dp"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Anticipo de Crédito ($)"
                        android:textSize="12sp"
                        android:textColor="@color/terracota"
                        android:layout_marginBottom="4dp" />
                    <EditText
                        android:id="@+id/et_anticipo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:text="0"
                        android:background="@drawable/bg_edittext_corporate"
                        android:padding="12dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_finalizar_venta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="FINALIZAR TRANSACCIÓN"
                    android:backgroundTint="@color/teal"
                    android:textColor="@color/white"
                    android:padding="14dp"
                    app:cornerRadius="4dp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btn_back_to_step1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MODIFICAR PRODUCTOS"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textColor="@color/gris_medio"
                    android:textSize="11sp" />

            </LinearLayout>
        </ScrollView>

    </FrameLayout>

</LinearLayout>
