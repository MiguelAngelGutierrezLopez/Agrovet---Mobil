<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/blanco_hueso">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@color/teal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:title="@string/label_registro_venta"
            app:titleTextColor="@color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:elevation="2dp"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/step1_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:id="@+id/step1_circle"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_circle_teal"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/step1_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_productos"
                    android:textColor="@color/teal"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="0.5"
                android:layout_gravity="center"
                android:background="@color/teal"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <LinearLayout
                android:id="@+id/step2_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:id="@+id/step2_circle"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_circle_gris"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/step2_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_pago"
                    android:textColor="@color/gris_medio"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/blanco_hueso">

            <LinearLayout
                android:id="@+id/layout_step1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="visible"
                android:background="@color/blanco_hueso">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/et_buscar_producto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_edittext_corporate"
                        android:hint="@string/hint_buscar_producto"
                        android:padding="12dp"
                        android:textColor="@color/gris_oscuro"
                        android:textColorHint="@color/gris_medio"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btn_venta_especifica"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/label_venta_especifica"
                        android:textColor="@color/teal"
                        android:textSize="10sp"
                        app:strokeColor="@color/teal" />
                </LinearLayout>

                <AutoCompleteTextView
                    android:id="@+id/et_buscar_cliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_edittext_corporate"
                    android:hint="@string/hint_nombre_comprador"
                    android:padding="12dp"
                    android:textColor="@color/gris_oscuro"
                    android:textColorHint="@color/gris_medio"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:scrollbars="none">
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/cg_filtro_categorias"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true">
                    </com.google.android.material.chip.ChipGroup>
                </HorizontalScrollView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_productos_disponibles"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_items_carrito"
                            android:textColor="@color/teal"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_carrito"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:layout_marginTop="8dp" />

                        <Button
                            android:id="@+id/btn_next_step"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:backgroundTint="@color/teal"
                            android:text="@string/btn_continuar_pago"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            app:cornerRadius="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <ScrollView
                android:id="@+id/layout_step2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:visibility="gone"
                android:background="@color/blanco_hueso">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="16dp"
                                android:text="@string/label_resumen_venta"
                                android:textColor="@color/teal"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/label_descuento_field"
                                    android:textColor="@color/gris_oscuro"
                                    android:textSize="14sp" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="$"
                                        android:textColor="@color/gris_medio"
                                        android:textSize="14sp"
                                        android:layout_gravity="center" />

                                    <EditText
                                        android:id="@+id/et_descuento"
                                        android:layout_width="80dp"
                                        android:layout_height="wrap_content"
                                        android:background="@drawable/bg_edittext_corporate"
                                        android:gravity="end"
                                        android:inputType="numberDecimal"
                                        android:padding="8dp"
                                        android:text="0"
                                        android:textColor="@color/gris_oscuro"
                                        android:textColorHint="@color/gris_medio"
                                        android:textSize="14sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/gris_claro"
                                android:layout_marginVertical="8dp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="8dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/label_subtotal_field"
                                    android:textColor="@color/gris_medio"
                                    android:textSize="14sp" />

                                <TextView
                                    android:id="@+id/txt_resumen_subtotal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="$ 0.00"
                                    android:textColor="@color/gris_oscuro"
                                    android:textSize="14sp" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/label_total_pagar"
                                    android:textColor="@color/gris_oscuro"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/txt_total_venta"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="$ 0.00"
                                    android:textColor="@color/teal"
                                    android:textSize="20sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>


                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="16dp"
                                android:text="@string/label_info_pago"
                                android:textColor="@color/teal"
                                android:textSize="14sp"
                                android:textStyle="bold" />


                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/label_monto_recibido"
                                    android:textColor="@color/gris_oscuro"
                                    android:textSize="14sp" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="$"
                                        android:textColor="@color/gris_medio"
                                        android:textSize="14sp"
                                        android:layout_gravity="center" />

                                    <EditText
                                        android:id="@+id/et_monto_recibido"
                                        android:layout_width="120dp"
                                        android:layout_height="wrap_content"
                                        android:background="@drawable/bg_edittext_corporate"
                                        android:gravity="end"
                                        android:hint="0.00"
                                        android:inputType="numberDecimal"
                                        android:padding="10dp"
                                        android:textColor="@color/gris_oscuro"
                                        android:textColorHint="@color/gris_medio"
                                        android:textSize="14sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="16dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/label_cambio_vuelto"
                                    android:textColor="@color/verde_exito"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/txt_vuelto"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="$ 0.00"
                                    android:textColor="@color/verde_exito"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/gris_claro"
                                android:layout_marginVertical="8dp" />


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:layout_marginTop="4dp"
                                android:text="@string/label_metodo_pago_caps"
                                android:textColor="@color/gris_medio"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:id="@+id/layout_metodo_pago"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="16dp"
                                android:orientation="horizontal">

                                <com.google.android.material.card.MaterialCardView
                                    android:id="@+id/card_contado"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="8dp"
                                    app:cardCornerRadius="8dp"
                                    app:cardElevation="0dp"
                                    app:strokeColor="@color/teal"
                                    app:strokeWidth="2dp">

                                    <RadioButton
                                        android:id="@+id/rb_contado"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:button="@null"
                                        android:checked="true"
                                        android:gravity="center"
                                        android:padding="12dp"
                                        android:text="@string/metodo_efectivo"
                                        android:textAlignment="center"
                                        android:textColor="@color/teal"
                                        android:textStyle="bold"
                                        android:textSize="12sp" />
                                </com.google.android.material.card.MaterialCardView>

                                <com.google.android.material.card.MaterialCardView
                                    android:id="@+id/card_credito"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="4dp"
                                    android:layout_marginEnd="4dp"
                                    app:cardCornerRadius="8dp"
                                    app:cardElevation="0dp"
                                    app:strokeColor="@color/gris_claro"
                                    app:strokeWidth="1dp">

                                    <RadioButton
                                        android:id="@+id/rb_credito"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:button="@null"
                                        android:gravity="center"
                                        android:padding="12dp"
                                        android:text="@string/metodo_credito"
                                        android:textAlignment="center"
                                        android:textColor="@color/gris_oscuro"
                                        android:textSize="12sp" />
                                </com.google.android.material.card.MaterialCardView>

                                <com.google.android.material.card.MaterialCardView
                                    android:id="@+id/card_banco"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="8dp"
                                    app:cardCornerRadius="8dp"
                                    app:cardElevation="0dp"
                                    app:strokeColor="@color/gris_claro"
                                    app:strokeWidth="1dp">

                                    <RadioButton
                                        android:id="@+id/rb_banco"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:button="@null"
                                        android:gravity="center"
                                        android:padding="12dp"
                                        android:text="@string/metodo_banco"
                                        android:textAlignment="center"
                                        android:textColor="@color/gris_oscuro"
                                        android:textSize="12sp" />
                                </com.google.android.material.card.MaterialCardView>
                            </LinearLayout>


                            <LinearLayout
                                android:id="@+id/layout_banco_options"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="16dp"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp"
                                    android:text="@string/prompt_tipo_pago"
                                    android:textColor="@color/gris_medio"
                                    android:textSize="11sp" />

                                <com.google.android.material.chip.ChipGroup
                                    android:id="@+id/cg_submetodo_banco"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    app:singleSelection="true"
                                    app:selectionRequired="true">

                                    <com.google.android.material.chip.Chip
                                        android:id="@+id/chip_nequi"
                                        style="@style/Widget.MaterialComponents.Chip.Choice"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:checked="true"
                                        android:text="Nequi"
                                        app:chipBackgroundColor="@color/blanco_hueso"
                                        app:chipStrokeColor="@color/teal"
                                        app:chipStrokeWidth="1dp" />

                                    <com.google.android.material.chip.Chip
                                        android:id="@+id/chip_transaccion"
                                        style="@style/Widget.MaterialComponents.Chip.Choice"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="Transacción"
                                        app:chipBackgroundColor="@color/blanco_hueso"
                                        app:chipStrokeColor="@color/gris_claro"
                                        app:chipStrokeWidth="1dp" />

                                    <com.google.android.material.chip.Chip
                                        android:id="@+id/chip_tarjeta"
                                        style="@style/Widget.MaterialComponents.Chip.Choice"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:text="Tarjeta"
                                        app:chipBackgroundColor="@color/blanco_hueso"
                                        app:chipStrokeColor="@color/gris_claro"
                                        app:chipStrokeWidth="1dp" />
                                </com.google.android.material.chip.ChipGroup>
                            </LinearLayout>


                            <LinearLayout
                                android:id="@+id/layout_anticipo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:layout_marginBottom="12dp">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:layout_marginEnd="8dp">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginBottom="4dp"
                                            android:text="@string/label_anticipo_credito"
                                            android:textColor="@color/terracota"
                                            android:textSize="13sp" />

                                        <LinearLayout
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:orientation="horizontal">

                                            <TextView
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:text="$"
                                                android:textColor="@color/gris_medio"
                                                android:textSize="14sp"
                                                android:layout_gravity="center" />

                                            <EditText
                                                android:id="@+id/et_anticipo"
                                                android:layout_width="match_parent"
                                                android:layout_height="wrap_content"
                                                android:layout_marginStart="4dp"
                                                android:background="@drawable/bg_edittext_corporate"
                                                android:inputType="numberDecimal"
                                                android:padding="12dp"
                                                android:text="0"
                                                android:textColor="@color/gris_oscuro"
                                                android:textColorHint="@color/gris_medio"
                                                android:textSize="14sp" />
                                        </LinearLayout>
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:layout_marginStart="8dp">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginBottom="4dp"
                                            android:text="@string/label_dias_credito"
                                            android:textColor="@color/gris_oscuro"
                                            android:textSize="13sp" />

                                        <EditText
                                            android:id="@+id/et_dias_credito"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:background="@drawable/bg_edittext_corporate"
                                            android:inputType="number"
                                            android:padding="12dp"
                                            android:text="30"
                                            android:textColor="@color/gris_oscuro"
                                            android:textColorHint="@color/gris_medio"
                                            android:textSize="14sp" />
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>


                    <Button
                        android:id="@+id/btn_finalizar_venta"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="12dp"
                        android:backgroundTint="@color/teal"
                        android:padding="14dp"
                        android:text="@string/btn_finalizar_venta"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        app:cornerRadius="8dp" />

                    <Button
                        android:id="@+id/btn_back_to_step1"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/btn_modificar_productos"
                        android:textColor="@color/gris_medio"
                        android:textSize="12sp" />

                </LinearLayout>
            </ScrollView>

        </FrameLayout>

    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header_main"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
