<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F0E6">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#008080"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:titleTextColor="@color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:background="@color/white"
        android:layout_margin="20dp"
        android:elevation="4dp">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registro de Venta"
                android:textColor="#008080"
                android:textSize="22sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Complete la información de la venta"
                android:textColor="#9E9E9E"
                android:textSize="13sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="12dp"
            android:background="#E3F0F3">
            <TextView
                android:id="@+id/txt_ticket_numero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#0016"
                android:textColor="#008080"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Número de venta"
                android:textSize="11sp"
                android:textColor="#7f8c8d" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp">
        <Button
            android:id="@+id/btn_venta_normal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📋 Venta Normal"
            android:backgroundTint="#008080"
            android:textColor="@color/white"
            android:layout_marginEnd="6dp" />
        <Button
            android:id="@+id/btn_venta_mixta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔄 Venta Mixta"
            android:backgroundTint="@color/white"
            android:textColor="#4A4A4A"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="20dp"
        android:baselineAligned="false">

        <!-- Panel Izquierdo: Productos -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/white"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginEnd="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Productos Disponibles"
                android:textColor="#008080"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp">
                <EditText
                    android:id="@+id/et_buscar_producto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Buscar producto por nombre..."
                    android:padding="12dp"
                    android:background="@color/blanco_hueso"
                    android:textSize="14sp" />
            </androidx.cardview.widget.CardView>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_productos_disponibles"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

        <!-- Panel Derecho: Carrito -->
        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginStart="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Productos en Venta"
                android:textColor="#008080"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#E8E8E8"
                android:padding="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Producto" android:textSize="11sp" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Cant" android:textSize="11sp" android:textStyle="bold" android:gravity="center" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="Total" android:textSize="11sp" android:textStyle="bold" android:gravity="end" />
                <View android:layout_width="24dp" android:layout_height="0dp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_carrito"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#008080"
                android:layout_marginTop="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TOTAL"
                    android:textColor="#008080"
                    android:textStyle="bold"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/txt_total_venta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$ 0.00"
                    android:textColor="#008080"
                    android:textStyle="bold"
                    android:textSize="18sp" />
            </LinearLayout>

            <RadioGroup
                android:id="@+id/rg_metodo_pago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp">
                <RadioButton android:id="@+id/rb_contado" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Contado" android:textSize="11sp" android:checked="true" />
                <RadioButton android:id="@+id/rb_credito" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Credito" android:textSize="11sp" />
                <RadioButton android:id="@+id/rb_banco" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Banco" android:textSize="11sp" />
            </RadioGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button
                    android:id="@+id/btn_cancelar_venta"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cancelar"
                    android:backgroundTint="#E8E8E8"
                    android:textColor="#4A4A4A"
                    android:layout_marginEnd="6dp" />
                <Button
                    android:id="@+id/btn_finalizar_venta"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:text="Finalizar Venta"
                    android:backgroundTint="#008080"
                    android:textColor="@color/white"
                    android:layout_marginStart="6dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
