<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    android:backgroundTint="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp"
        android:background="@drawable/bg_card_border">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/txt_venta_ticket"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="#0000"
                android:textColor="@color/teal"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.03" />

            <TextView
                android:id="@+id/txt_venta_fecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15/05/2026 10:30"
                android:textColor="@color/gris_claro"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txt_venta_cliente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CLIENTE NOMBRE"
            android:textColor="@color/gris_oscuro"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Productos y servicios registrados"
            android:textColor="@color/gris_medio"
            android:textSize="11sp"
            android:paddingBottom="8dp"
            android:background="@drawable/bg_bottom_divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="12dp">

            <TextView
                android:id="@+id/txt_venta_total"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="$ 0.00"
                android:textColor="@color/gris_oscuro"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_venta_metodo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTADO"
                style="@style/Widget.Agrovet.Badge"
                android:background="@drawable/bg_badge_contado"
                android:textColor="@color/verde_exito" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:paddingTop="10dp"
            android:background="@drawable/bg_top_divider">

            <Button
                android:id="@+id/btn_venta_ver"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Detalle"
                android:textSize="11sp"
                android:textColor="#5D6D7E"
                android:backgroundTint="@android:color/transparent"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#D0CBC2"
                android:padding="8dp"
                app:cornerRadius="4dp" />

            <View android:layout_width="10dp" android:layout_height="0dp" />

            <Button
                android:id="@+id/btn_venta_eliminar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Eliminar"
                android:textSize="11sp"
                android:textColor="@color/rojo_error"
                android:backgroundTint="@color/rojo_fondo"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:padding="8dp"
                app:cornerRadius="4dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
