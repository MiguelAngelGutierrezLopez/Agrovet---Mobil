<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_venta"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    style="@style/Widget.Agrovet.Card.ListItem">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@drawable/bg_card_border">

        <!-- Fila superior: Ticket y Fecha -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/txt_venta_ticket"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="#0000"
                android:textColor="@color/teal"
                android:textStyle="bold"
                android:textSize="11sp"
                android:letterSpacing="0.03" />

            <TextView
                android:id="@+id/txt_venta_fecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15/05/2026"
                android:textColor="@color/gris_medio"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Cliente -->
        <TextView
            android:id="@+id/txt_venta_cliente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CLIENTE NOMBRE"
            android:textColor="@color/gris_oscuro"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Línea divisoria -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/separador"
            android:layout_marginBottom="6dp" />

        <!-- Total y Método de pago -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/txt_venta_total"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="$ 0.00"
                android:textColor="@color/teal"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_venta_metodo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTADO"
                android:background="@drawable/bg_badge_contado"
                android:textColor="@color/verde_exito"
                style="@style/Widget.Agrovet.Badge"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textSize="9sp" />
        </LinearLayout>

        <!-- Botones de acción (más compactos) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="6dp"
            android:background="@drawable/bg_top_divider">

            <Button
                android:id="@+id/btn_venta_ver"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_ver"
                android:textSize="11sp"
                android:paddingVertical="6dp"
                style="@style/Widget.Agrovet.Button.Action.Edit" />

            <View android:layout_width="8dp" android:layout_height="0dp" />

            <Button
                android:id="@+id/btn_venta_eliminar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_eliminar"
                android:textSize="11sp"
                android:paddingVertical="6dp"
                style="@style/Widget.Agrovet.Button.Action.Delete" />
        </LinearLayout>

        <!-- Panel detallado (colapsado por defecto) -->
        <LinearLayout
            android:id="@+id/layout_detalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:paddingTop="8dp"
            android:background="@drawable/bg_top_divider">

            <!-- Información General -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_info_general"
                style="@style/TextAppearance.Agrovet.Label"
                android:textColor="@color/teal"
                android:textSize="11sp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/gris_suave"
                android:padding="8dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="@string/label_nro_ticket"
                        android:textColor="@color/gris_medio"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/detalle_ticket"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="#0000"
                        android:textColor="@color/teal"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="@string/label_fecha"
                        android:textColor="@color/gris_medio"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/detalle_fecha"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="15/05/2026 10:30"
                        android:textColor="@color/gris_oscuro"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="@string/label_cliente"
                        android:textColor="@color/gris_medio"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/detalle_cliente"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Consumidor Final"
                        android:textColor="@color/gris_oscuro"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="@string/label_metodo_pago"
                        android:textColor="@color/gris_medio"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/detalle_metodo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONTADO"
                        android:textColor="@color/verde_exito"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Resumen Económico -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_resumen_economico"
                style="@style/TextAppearance.Agrovet.Label"
                android:textColor="@color/teal"
                android:textSize="11sp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/gris_suave"
                android:padding="8dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_subtotal"
                        android:textColor="@color/gris_medio"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/detalle_subtotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$ 0.00"
                        android:textColor="@color/gris_oscuro"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_descuento"
                        android:textColor="@color/gris_medio"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/detalle_descuento"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$ 0.00"
                        android:textColor="@color/rojo_error"
                        android:textSize="10sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/separador"
                    android:layout_marginVertical="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_total"
                        android:textColor="@color/teal"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/detalle_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$ 0.00"
                        android:textColor="@color/teal"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Para crédito -->
            <LinearLayout
                android:id="@+id/detalle_credito_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_info_credito"
                    style="@style/TextAppearance.Agrovet.Label"
                    android:textColor="@color/terracota"
                    android:textSize="11sp"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/gris_suave"
                    android:padding="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_anticipo"
                            android:textColor="@color/gris_medio"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/detalle_anticipo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$ 0.00"
                            android:textColor="@color/gris_oscuro"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_saldo_pendiente"
                            android:textColor="@color/terracota"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/detalle_saldo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$ 0.00"
                            android:textColor="@color/terracota"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>