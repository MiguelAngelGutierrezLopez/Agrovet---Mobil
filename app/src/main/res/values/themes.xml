<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AgrovetPOS" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/teal</item>

        <item name="colorPrimary">@color/teal</item>
        <item name="colorPrimaryVariant">@color/teal_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/terracota</item>
        <item name="colorSecondaryVariant">@color/terracota</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/blanco_hueso</item>

        <item name="android:editTextColor">@color/gris_oscuro</item>
        <item name="android:textColorPrimary">@color/gris_oscuro</item>
        <item name="android:textColorSecondary">@color/gris_medio</item>
        <item name="android:textColorHint">@color/gris_claro</item>

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Widget.Agrovet" parent="" />

    <!-- Toolbar Style -->
    <style name="Widget.Agrovet.Toolbar" parent="Widget.AppCompat.Toolbar">
        <item name="android:background">@color/teal</item>
        <item name="android:minHeight">60dp</item>
        <item name="titleTextColor">@color/white</item>
        <item name="subtitleTextColor">#B3FFFFFF</item>
    </style>

    <!-- Buttons -->
    <style name="Widget.Agrovet.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/teal</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Stats Cards -->
    <style name="Widget.Agrovet.Card.Stats" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- List Cards -->
    <style name="Widget.Agrovet.Card.ListItem" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>

    <!-- Period Buttons -->
    <style name="Widget.Agrovet.Button.Period" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:background">@color/white</item>
        <item name="android:textColor">@color/gris_medio</item>
        <item name="cornerRadius">8dp</item>
        <item name="strokeColor">@color/borde_sutil</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Agrovet.Button.Period.Active">
        <item name="android:background">@color/teal</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Badges -->
    <style name="Widget.Agrovet.Badge">
        <item name="android:textSize">9sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- General Typography -->
    <style name="TextAppearance.Agrovet.Headline" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/gris_oscuro</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="TextAppearance.Agrovet.Label" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textColor">@color/gris_medio</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
