<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AgrovetPOS" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/teal</item>

        <item name="colorPrimary">@color/teal</item>
        <item name="colorPrimaryVariant">@color/teal_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/terracota</item>
        <item name="colorSecondaryVariant">@color/terracota</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/blanco_hueso</item>

        <item name="android:editTextColor">@color/gris_oscuro</item>
        <item name="android:textColorPrimary">@color/gris_oscuro</item>
        <item name="android:textColorSecondary">@color/gris_medio</item>
        <item name="android:textColorHint">@color/gris_medio</item>

        <item name="dialogTheme">@style/Theme.AgrovetPOS.Dialog</item>
        <item name="alertDialogTheme">@style/Theme.AgrovetPOS.Dialog</item>

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Widget.Agrovet" parent="" />

    <!-- Toolbar Style -->
    <style name="Widget.Agrovet.Toolbar" parent="Widget.AppCompat.Toolbar">
        <item name="android:background">@color/teal</item>
        <item name="android:minHeight">60dp</item>
        <item name="titleTextColor">@color/white</item>
        <item name="subtitleTextColor">#B3FFFFFF</item>
    </style>

    <!-- Buttons -->
    <style name="Widget.Agrovet.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/teal</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Agrovet.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/teal</item>
        <item name="strokeColor">@color/teal</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Agrovet.Button.Action.Edit" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">#5D6D7E</item>
        <item name="strokeColor">#D0CBC2</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">4dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:padding">8dp</item>
        <item name="android:backgroundTint">@android:color/transparent</item>
    </style>

    <style name="Widget.Agrovet.Button.Action.Delete" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:textColor">@color/rojo_error</item>
        <item name="backgroundTint">@color/rojo_fondo</item>
        <item name="cornerRadius">4dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:padding">8dp</item>
    </style>

    <!-- Stats Cards -->
    <style name="Widget.Agrovet.Card.Stats" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- List Cards -->
    <style name="Widget.Agrovet.Card.ListItem" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>

    <!-- Period Buttons -->
    <style name="Widget.Agrovet.Button.Period" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:background">@color/white</item>
        <item name="android:textColor">@color/gris_medio</item>
        <item name="cornerRadius">8dp</item>
        <item name="strokeColor">@color/borde_sutil</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Agrovet.Button.Period.Active">
        <item name="android:background">@color/teal</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.Agrovet.Button.Login" parent="Widget.Agrovet.Button.Primary">
        <item name="android:padding">14dp</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Badges -->
    <style name="Widget.Agrovet.Badge">
        <item name="android:textSize">9sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- General Typography -->
    <style name="TextAppearance.Agrovet.Headline" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/gris_oscuro</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="TextAppearance.Agrovet.Headline.Dialog">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/teal</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Agrovet.Label" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textColor">@color/gris_medio</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Agrovet.Label.Field">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/gris_oscuro</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- TextInputLayout -->
    <style name="Widget.Agrovet.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/teal</item>
        <item name="hintTextColor">@color/teal</item>
        <item name="boxCornerRadiusBottomEnd">6dp</item>
        <item name="boxCornerRadiusBottomStart">6dp</item>
        <item name="boxCornerRadiusTopEnd">6dp</item>
        <item name="boxCornerRadiusTopStart">6dp</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:background">@color/white</item>
    </style>

    <style name="Widget.Agrovet.TextInputLayout.ExposedDropdownMenu" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxStrokeColor">@color/teal</item>
        <item name="hintTextColor">@color/teal</item>
        <item name="boxCornerRadiusBottomEnd">6dp</item>
        <item name="boxCornerRadiusBottomStart">6dp</item>
        <item name="boxCornerRadiusTopEnd">6dp</item>
        <item name="boxCornerRadiusTopStart">6dp</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:background">@color/white</item>
    </style>

    <style name="Widget.Agrovet.Card.Selector" parent="Widget.Agrovet.Card.Stats">
        <item name="strokeColor">@color/teal</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>

    <style name="Theme.AgrovetPOS.Dialog" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:colorBackground">@color/white</item>
        <item name="colorPrimary">@color/teal</item>
    </style>

</resources>
