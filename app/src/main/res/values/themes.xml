<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AgrovetPOS" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/teal</item>

        <item name="colorPrimary">@color/teal</item>
        <item name="colorPrimaryVariant">@color/teal_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/terracota</item>
        <item name="colorSecondaryVariant">@color/terracota</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/blanco_hueso</item>

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.AgrovetPOS.WithActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/teal</item>
        <item name="colorPrimary">@color/teal</item>
        <item name="colorPrimaryVariant">@color/teal_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/terracota</item>
        <item name="colorSecondaryVariant">@color/terracota</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/blanco_hueso</item>
    </style>

    <!-- ESTILOS REUTILIZABLES -->

    <!-- Tarjetas de Estadísticas (Dashboard) -->
    <style name="Widget.Agrovet.Card.Stats" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <!-- Botones de Acción Estilo Card (Grid y Listas) -->
    <style name="Widget.Agrovet.Card.Action" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">3dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <!-- Contenedor de Items en Listas -->
    <style name="Widget.Agrovet.Card.ListItem" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>

    <!-- Tarjeta de Barra de Búsqueda -->
    <style name="Widget.Agrovet.Card.Search" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <!-- Botones de Guardar/Primarios -->
    <style name="Widget.Agrovet.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Estilos de Texto -->
    <style name="TextAppearance.Agrovet.Headline" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/gris_oscuro</item>
    </style>

    <style name="TextAppearance.Agrovet.Subhead" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textColor">@color/gris_medio</item>
    </style>

</resources>
